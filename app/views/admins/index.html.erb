<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-shield-lock-fill"></i> 管理者一覧</h2>
  <%= link_to "新規登録", new_admin_path, class: "btn btn-primary" %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>名前</th><th>メールアドレス</th><th>権限</th><th></th></tr>
      </thead>
      <tbody>
        <% @admins.each do |admin| %>
          <tr>
            <td><%= admin.name %> <%= "（自分）" if admin == current_admin %></td>
            <td><%= admin.email %></td>
            <td><span class="badge bg-<%= admin.super_admin? ? 'danger' : 'secondary' %>"><%= admin.super_admin? ? 'スーパー管理者' : '管理者' %></span></td>
            <td class="text-end">
              <%= link_to "編集", edit_admin_path(admin), class: "btn btn-sm btn-outline-primary" %>
              <% if current_admin.super_admin? && admin != current_admin %>
                <%= button_to "削除", admin_path(admin), method: :delete, class: "btn btn-sm btn-outline-danger",
                    data: { turbo_confirm: "#{admin.name} を削除しますか？" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<%= paginate @admins %>
