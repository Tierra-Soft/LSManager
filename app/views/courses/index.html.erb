<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-book-fill"></i> コース一覧</h2>
  <%= link_to "新規作成", new_course_path, class: "btn btn-primary" %>
</div>

<div class="row g-3">
  <% @courses.each do |course| %>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <h5 class="card-title"><%= link_to course.title, course_path(course) %></h5>
            <% badge = { "draft" => "secondary", "published" => "success", "archived" => "warning" }[course.status] %>
            <span class="badge bg-<%= badge %>"><%= course.status %></span>
          </div>
          <p class="card-text text-muted"><%= truncate(course.description, length: 80) %></p>
          <small class="text-muted">レッスン: <%= course.lessons.count %>件 / 受講者: <%= course.students.count %>人</small>
        </div>
        <div class="card-footer d-flex gap-2">
          <%= link_to "詳細", course_path(course), class: "btn btn-sm btn-outline-info" %>
          <%= link_to "編集", edit_course_path(course), class: "btn btn-sm btn-outline-primary" %>
          <%= button_to "削除", course_path(course), method: :delete, class: "btn btn-sm btn-outline-danger",
              data: { turbo_confirm: "#{course.title} を削除しますか？" } %>
        </div>
      </div>
    </div>
  <% end %>
  <% if @courses.empty? %>
    <div class="col-12"><p class="text-center text-muted py-4">コースが登録されていません</p></div>
  <% end %>
</div>
<%= paginate @courses %>
