<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-clock-history"></i> メール送信ログ</h2>
</div>

<div class="card mb-3">
  <div class="card-body py-2">
    <%= form_with url: email_logs_path, method: :get, class: "row g-2 align-items-center" do |f| %>
      <div class="col-md-4">
        <%= f.select :status, [["全ステータス", ""]].concat(EmailLog.statuses.map { |k, _| [k, k] }),
            { selected: params[:status] }, class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <%= f.submit "絞り込み", class: "btn btn-sm btn-primary" %>
        <%= link_to "リセット", email_logs_path, class: "btn btn-sm btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>受講者</th><th>テンプレート</th><th>送信日時</th><th>状態</th><th></th></tr>
      </thead>
      <tbody>
        <% @logs.each do |log| %>
          <tr>
            <td><%= log.student ? link_to(log.student.name, student_path(log.student)) : "-" %></td>
            <td><%= log.email_template&.name || "（削除済み）" %></td>
            <td>
              <% if log.pending? %>
                <i class="bi bi-alarm text-warning"></i>
                <%= log.scheduled_at&.strftime("%Y/%m/%d %H:%M") %> 予定
              <% else %>
                <%= log.sent_at&.strftime("%Y/%m/%d %H:%M") %>
              <% end %>
            </td>
            <td>
              <% badge = { "sent" => "success", "failed" => "danger", "pending" => "warning" }[log.status] %>
              <% label = { "sent" => "送信済", "failed" => "失敗", "pending" => "予約中" }[log.status] %>
              <span class="badge bg-<%= badge %> <%= log.pending? ? 'text-dark' : '' %>"><%= label %></span>
            </td>
            <td><%= link_to "詳細", email_log_path(log), class: "btn btn-sm btn-outline-info" %></td>
          </tr>
        <% end %>
        <% if @logs.empty? %>
          <tr><td colspan="5" class="text-center text-muted py-4">送信ログがありません</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<%= paginate @logs %>
