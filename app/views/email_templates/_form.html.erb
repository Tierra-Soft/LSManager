<%= form_with model: template do |f| %>
  <% if template.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% template.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :name, "テンプレート名", class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>
    <div class="col-md-6">
      <%= f.label :category, "カテゴリ", class: "form-label" %>
      <%= f.select :category, EmailTemplate.categories.map { |k, _| [k, k] }, {}, class: "form-select" %>
    </div>
    <div class="col-12">
      <%= f.label :subject, "件名", class: "form-label" %>
      <%= f.text_field :subject, class: "form-control", required: true,
          placeholder: "例: {{name}} 様へのお知らせ" %>
    </div>
    <div class="col-12">
      <%= f.label :body, "本文", class: "form-label" %>
      <%= f.text_area :body, class: "form-control", rows: 10, required: true,
          placeholder: "{{name}} 様\n\nお世話になっております。\n..." %>
      <small class="text-muted">使用可能な変数: <code>{{name}}</code> <code>{{student_code}}</code> <code>{{department}}</code></small>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3">
    <%= f.submit template.new_record? ? "作成" : "更新", class: "btn btn-primary" %>
    <%= link_to "キャンセル", email_templates_path, class: "btn btn-secondary" %>
  </div>
<% end %>
