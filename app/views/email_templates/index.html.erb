<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-envelope-fill"></i> メールテンプレート</h2>
  <%= link_to "新規作成", new_email_template_path, class: "btn btn-primary" %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>名前</th><th>カテゴリ</th><th>件名</th><th></th></tr>
      </thead>
      <tbody>
        <% @templates.each do |template| %>
          <tr>
            <td><%= link_to template.name, email_template_path(template) %></td>
            <td><span class="badge bg-info"><%= template.category %></span></td>
            <td><%= truncate(template.subject, length: 50) %></td>
            <td class="text-end">
              <%= link_to "詳細/送信", email_template_path(template), class: "btn btn-sm btn-outline-success" %>
              <%= link_to "編集", edit_email_template_path(template), class: "btn btn-sm btn-outline-primary" %>
              <%= button_to "削除", email_template_path(template), method: :delete,
                  class: "btn btn-sm btn-outline-danger",
                  data: { turbo_confirm: "#{template.name} を削除しますか？" } %>
            </td>
          </tr>
        <% end %>
        <% if @templates.empty? %>
          <tr><td colspan="4" class="text-center text-muted py-4">テンプレートがありません</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<%= paginate @templates %>
