<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-envelope-fill"></i> <%= @template.name %></h2>
  <div class="d-flex gap-2">
    <%= link_to "編集", edit_email_template_path(@template), class: "btn btn-outline-primary" %>
    <%= link_to "一覧へ", email_templates_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-5">
    <div class="card mb-3">
      <div class="card-header">テンプレート内容</div>
      <div class="card-body">
        <dl class="row">
          <dt class="col-4">カテゴリ</dt>
          <dd class="col-8"><span class="badge bg-info"><%= @template.category %></span></dd>
          <dt class="col-4">件名</dt>
          <dd class="col-8"><%= @template.subject %></dd>
        </dl>
        <hr>
        <h6>本文</h6>
        <div class="bg-light p-3 rounded border" style="white-space:pre-wrap"><%= @template.body %></div>
        <small class="text-muted mt-2 d-block">使用可能な変数: <code>{{name}}</code> <code>{{student_code}}</code> <code>{{department}}</code></small>
      </div>
    </div>
  </div>

  <div class="col-md-7">
    <div class="card">
      <div class="card-header">メール送信</div>
      <div class="card-body">
        <%= form_with url: preview_email_template_path(@template), method: :post, data: { turbo: false } do |f| %>
          <div class="mb-3">
            <label class="form-label fw-bold">受講者を選択</label>
            <div style="max-height:300px;overflow-y:auto;border:1px solid #dee2e6;border-radius:4px;padding:8px">
              <% Student.active.order(:name).each do |student| %>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="student_ids[]"
                         value="<%= student.id %>" id="student_<%= student.id %>">
                  <label class="form-check-label" for="student_<%= student.id %>">
                    <%= student.name %> <small class="text-muted">(<%= student.email %>)</small>
                  </label>
                </div>
              <% end %>
            </div>
          </div>
          <div class="d-flex gap-2">
            <%= f.submit "内容を確認する →", class: "btn btn-outline-primary" %>
          </div>
        <% end %>
        <hr>
        <%= form_with url: bulk_send_email_templates_path, method: :post do |f| %>
          <%= f.hidden_field :email_template_id, value: @template.id %>
          <%= f.submit "全アクティブ受講者に一括送信", class: "btn btn-warning",
              data: { turbo_confirm: "全てのアクティブ受講者にメールを送信しますか？" } %>
        <% end %>
      </div>
    </div>
  </div>
</div>
