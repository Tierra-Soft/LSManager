<%= form_with model: [@course, lesson] do |f| %>
  <% if lesson.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% lesson.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, "レッスン名", class: "form-label" %>
    <%= f.text_field :title, class: "form-control", required: true %>
  </div>
  <div class="mb-3">
    <%= f.label :description, "説明", class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3 %>
  </div>
  <div class="mb-3">
    <%= f.label :position, "順番", class: "form-label" %>
    <%= f.number_field :position, class: "form-control", min: 1, required: true %>
  </div>
  <div class="d-flex gap-2">
    <%= f.submit lesson.new_record? ? "追加" : "更新", class: "btn btn-primary" %>
    <%= link_to "キャンセル", course_path(@course), class: "btn btn-secondary" %>
  </div>
<% end %>
