<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-graph-up"></i> 進捗管理 — <%= @student.name %></h2>
  <%= link_to "受講者詳細へ", student_path(@student), class: "btn btn-secondary" %>
</div>

<% @enrollments.each do |enrollment| %>
  <div class="card mb-4">
    <div class="card-header fw-bold"><i class="bi bi-book"></i> <%= enrollment.course.title %></div>
    <div class="list-group list-group-flush">
      <% enrollment.course.lessons.each do |lesson| %>
        <% progress = @progresses[lesson.id] %>
        <div class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <span class="badge bg-secondary me-2"><%= lesson.position %></span>
            <%= lesson.title %>
            <% if progress&.completed_at %>
              <small class="text-success ms-2"><i class="bi bi-check-circle"></i> <%= progress.completed_at.strftime("%Y/%m/%d") %>完了</small>
            <% end %>
          </div>
          <% if progress %>
            <%= form_with url: student_progress_path(@student, progress), method: :patch, class: "d-inline" do |f| %>
              <%= f.select :status, Progress.statuses.map { |k, _| [k, k] }, { selected: progress.status },
                  class: "form-select form-select-sm", style: "width:140px",
                  onchange: "this.form.requestSubmit()" %>
              <%= f.hidden_field :status %>
            <% end %>
          <% else %>
            <%= form_with url: student_progresses_path(@student), class: "d-inline" do |f| %>
              <%= f.hidden_field :lesson_id, value: lesson.id, name: "progress[lesson_id]" %>
              <%= f.select :status, Progress.statuses.map { |k, _| [k, k] }, {},
                  class: "form-select form-select-sm", style: "width:140px",
                  name: "progress[status]", onchange: "this.form.requestSubmit()" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @enrollments.empty? %>
  <div class="alert alert-info">コースに登録されていません。</div>
<% end %>
