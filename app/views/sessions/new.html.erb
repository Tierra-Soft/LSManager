<div class="row justify-content-center mt-5">
  <div class="col-md-4">
    <div class="card shadow">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0"><i class="bi bi-mortarboard-fill"></i> LSManager</h4>
        <small>セルフラーニング管理システム</small>
      </div>
      <div class="card-body p-4">
        <%= form_with url: login_path do |f| %>
          <div class="mb-3">
            <%= f.label :email, "メールアドレス", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true, autofocus: true %>
          </div>
          <div class="mb-3">
            <%= f.label :password, "パスワード", class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true %>
          </div>
          <%= f.submit "ログイン", class: "btn btn-primary w-100" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
