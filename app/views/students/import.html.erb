<h2 class="mb-4"><i class="bi bi-file-earmark-arrow-up-fill"></i> 受講者CSVインポート</h2>

<% if @errors&.any? %>
  <div class="alert alert-warning">
    <strong><%= @imported %>件インポート成功</strong>、以下のエラーがありました：
    <ul class="mb-0 mt-2">
      <% @errors.each do |err| %><li><%= err %></li><% end %>
    </ul>
  </div>
<% end %>

<div class="row">
  <div class="col-md-5">
    <div class="card mb-4">
      <div class="card-header">CSVファイルアップロード</div>
      <div class="card-body">
        <%= form_with url: import_students_path, multipart: true, data: { turbo: false } do |f| %>
          <div class="mb-3">
            <%= f.label :file, "CSVファイル", class: "form-label" %>
            <%= f.file_field :file, accept: ".csv", class: "form-control", required: true %>
          </div>
          <%= f.submit "プレビュー確認", class: "btn btn-success" %>
          <%= link_to "キャンセル", students_path, class: "btn btn-secondary" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-7">
    <div class="card">
      <div class="card-header">CSVカラム一覧（1行目はヘッダー行）</div>
      <div class="card-body p-0">
        <div class="table-responsive" style="max-height:400px;overflow-y:auto">
          <table class="table table-sm table-bordered mb-0">
            <thead class="table-light sticky-top">
              <tr><th>#</th><th>カラム名</th></tr>
            </thead>
            <tbody>
              <% Student::CSV_COLUMNS.keys.each_with_index do |col, i| %>
                <tr><td class="text-muted"><%= i + 1 %></td><td><code><%= col %></code></td></tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="p-2">
          <small class="text-muted">メールアドレスが同じ場合は上書き更新されます。</small>
        </div>
      </div>
    </div>
  </div>
</div>
