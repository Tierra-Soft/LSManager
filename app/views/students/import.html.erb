<h2 class="mb-4"><i class="bi bi-file-earmark-arrow-up-fill"></i> 受講者CSVインポート</h2>

<% if @errors&.any? %>
  <div class="alert alert-warning">
    <strong><%= @imported %>件インポート成功</strong>、以下のエラーがありました：
    <ul class="mb-0 mt-2">
      <% @errors.each do |err| %><li><%= err %></li><% end %>
    </ul>
  </div>
<% end %>

<div class="row">
  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-header">CSVファイルアップロード</div>
      <div class="card-body">
        <%= form_with url: import_students_path, multipart: true, data: { turbo: false } do |f| %>
          <div class="mb-3">
            <%= f.label :file, "CSVファイル", class: "form-label" %>
            <%= f.file_field :file, accept: ".csv", class: "form-control", required: true %>
          </div>
          <%= f.submit "インポート実行", class: "btn btn-success" %>
          <%= link_to "キャンセル", students_path, class: "btn btn-secondary" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-header">CSVフォーマット</div>
      <div class="card-body">
        <p class="text-muted">1行目はヘッダー行です。以下の列が必要です：</p>
        <table class="table table-sm table-bordered">
          <thead class="table-light">
            <tr><th>列名</th><th>説明</th><th>必須</th></tr>
          </thead>
          <tbody>
            <tr><td><code>student_code</code></td><td>学籍番号</td><td><span class="badge bg-danger">必須</span></td></tr>
            <tr><td><code>name</code></td><td>名前</td><td><span class="badge bg-danger">必須</span></td></tr>
            <tr><td><code>email</code></td><td>メールアドレス</td><td><span class="badge bg-danger">必須</span></td></tr>
            <tr><td><code>department</code></td><td>部署</td><td>任意</td></tr>
            <tr><td><code>enrolled_on</code></td><td>入学日 (YYYY-MM-DD)</td><td>任意</td></tr>
            <tr><td><code>status</code></td><td>active/inactive/completed</td><td>任意</td></tr>
          </tbody>
        </table>
        <p class="mb-0">
          <small class="text-muted">同一メールアドレスの場合は上書き更新されます。</small>
        </p>
      </div>
    </div>
  </div>
</div>
