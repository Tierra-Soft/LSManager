<h2 class="mb-4"><i class="bi bi-file-earmark-check-fill"></i> CSVインポート確認</h2>

<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="bi bi-table"></i> 先頭5件プレビュー</span>
    <span class="badge bg-secondary">全 <%= @total_rows %> 件</span>
  </div>
  <div class="table-responsive">
    <table class="table table-sm table-bordered mb-0">
      <thead class="table-light">
        <tr>
          <th>#</th>
          <% @preview_headers.each do |h| %>
            <th><code><%= h %></code></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @preview_rows.each.with_index(1) do |row, i| %>
          <tr>
            <td class="text-muted"><%= i %></td>
            <% row.each do |cell| %>
              <td><%= cell %></td>
            <% end %>
          </tr>
        <% end %>
        <% if @preview_rows.empty? %>
          <tr><td colspan="<%= @preview_headers.size + 1 %>" class="text-center text-muted py-3">データがありません</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if @total_rows > 5 %>
    <div class="card-footer text-muted small">… 残り <%= @total_rows - 5 %> 件は省略</div>
  <% end %>
</div>

<div class="d-flex gap-2">
  <%= form_with url: import_students_path do |f| %>
    <%= f.hidden_field :confirm, value: "1" %>
    <%= f.submit "#{@total_rows}件をインポートする", class: "btn btn-success" %>
  <% end %>
  <%= link_to "キャンセル（やり直す）", import_students_path, class: "btn btn-secondary" %>
</div>
