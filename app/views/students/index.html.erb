<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-people-fill"></i> 受講者一覧</h2>
  <div class="d-flex gap-2">
    <%= link_to "CSVインポート", import_students_path, class: "btn btn-outline-success" %>
    <%= link_to "CSVエクスポート", export_csv_students_path, class: "btn btn-outline-secondary" %>
    <%= link_to "新規登録", new_student_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="card mb-3">
  <div class="card-body py-2">
    <%= form_with url: students_path, method: :get, class: "row g-2 align-items-center" do |f| %>
      <div class="col-md-6">
        <%= f.text_field :q, value: params[:q], placeholder: "名前・メール・学籍番号で検索", class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-3">
        <%= f.select :status, [["全ステータス", ""]].concat(Student.statuses.map { |k, _| [k, k] }),
            { selected: params[:status] }, class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <%= f.submit "検索", class: "btn btn-sm btn-primary" %>
        <%= link_to "リセット", students_path, class: "btn btn-sm btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>学籍番号</th><th>名前</th><th>メールアドレス</th><th>部署</th><th>入学日</th><th>状態</th><th></th></tr>
      </thead>
      <tbody>
        <% @students.each do |student| %>
          <tr>
            <td><code><%= student.student_code %></code></td>
            <td><%= link_to student.name, student_path(student) %></td>
            <td><%= student.email %></td>
            <td><%= student.department %></td>
            <td><%= student.enrolled_on&.strftime("%Y/%m/%d") %></td>
            <td>
              <% badge = { "active" => "success", "inactive" => "secondary", "completed" => "primary" }[student.status] %>
              <span class="badge bg-<%= badge %>"><%= student.status %></span>
            </td>
            <td class="text-end">
              <%= link_to "詳細", student_path(student), class: "btn btn-sm btn-outline-info" %>
              <%= link_to "編集", edit_student_path(student), class: "btn btn-sm btn-outline-primary" %>
              <%= button_to "削除", student_path(student), method: :delete, class: "btn btn-sm btn-outline-danger",
                  data: { turbo_confirm: "#{student.name} を削除しますか？" } %>
            </td>
          </tr>
        <% end %>
        <% if @students.empty? %>
          <tr><td colspan="7" class="text-center text-muted py-4">受講者が登録されていません</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<%= paginate @students %>
