<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-people-fill"></i> 受講者一覧</h2>
  <div class="d-flex gap-2">
    <%= link_to "コース登録一覧", enrollment_matrix_students_path, class: "btn btn-outline-info" %>
    <%= link_to "CSVインポート", import_students_path, class: "btn btn-outline-success" %>
    <%= link_to "CSVエクスポート", export_csv_students_path, class: "btn btn-outline-secondary" %>
    <%= link_to "新規登録", new_student_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="card mb-3">
  <div class="card-body py-2">
    <%= form_with url: students_path, method: :get, class: "row g-2 align-items-center" do |f| %>
      <div class="col-md-6">
        <%= f.text_field :q, value: params[:q], placeholder: "氏名・フリガナ・メール・審判登録番号で検索", class: "form-control form-control-sm" %>
      </div>
      <div class="col-auto">
        <%= f.submit "検索", class: "btn btn-sm btn-primary" %>
        <%= link_to "リセット", students_path, class: "btn btn-sm btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<% offset = (@students.current_page - 1) * @students.limit_value %>
<div class="card">
  <div class="table-responsive">
    <table class="table table-hover table-sm mb-0 small">
      <thead class="table-light">
        <tr>
          <th class="text-center" style="width:3em">#</th>
          <th>氏名</th><th>フリガナ</th>
          <th>所属協会</th><th>技能区分</th><th>メールアドレス</th>
          <th>支払状況</th><th>結果</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% @students.each_with_index do |student, i| %>
          <tr>
            <td class="text-center text-muted"><%= offset + i + 1 %></td>
            <td><%= link_to student.name, student_path(student) %></td>
            <td><%= student.furigana %></td>
            <td><%= student.affiliated_association %></td>
            <td><%= student.skill_category %></td>
            <td><%= student.email %></td>
            <td><%= student.payment_status %></td>
            <td><%= student.result %></td>
            <td class="text-end text-nowrap">
              <%= link_to "詳細", student_path(student), class: "btn btn-sm btn-outline-info py-0" %>
              <%= link_to "編集", edit_student_path(student), class: "btn btn-sm btn-outline-primary py-0" %>
              <%= button_to "削除", student_path(student), method: :delete,
                  class: "btn btn-sm btn-outline-danger py-0",
                  form: { style: "display:inline" },
                  data: { turbo_confirm: "#{student.name} を削除しますか？" } %>
            </td>
          </tr>
        <% end %>
        <% if @students.empty? %>
          <tr><td colspan="9" class="text-center text-muted py-4">受講者が登録されていません</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<%= paginate @students %>
